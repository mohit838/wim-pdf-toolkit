generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

enum AdminRole {
  SUPERADMIN
  ADMIN
}

model AdminUser {
  id                     String                 @id @default(cuid())
  email                  String                 @unique
  name                   String
  role                   AdminRole
  passwordHash           String
  twoFactorEnabled       Boolean                @default(false)
  twoFactorSecret        String?
  twoFactorPendingSecret String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  sessions               AdminSession[]
  permissions            PermissionAssignment[]
}

model PermissionAssignment {
  id        String    @id @default(cuid())
  userId    String
  module    String
  action    String
  createdAt DateTime  @default(now())
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, module, action])
  @@index([module, action])
}

model AdminSession {
  id         String    @id @default(cuid())
  sessionId  String    @unique
  userId     String
  expiresAt  DateTime
  lastSeenAt DateTime
  revokedAt  DateTime?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model AuditLog {
  id         String    @id
  createdAt  DateTime  @default(now())
  actorId    String?
  actorEmail String?
  actorRole  AdminRole?
  action     String
  module     String
  target     String
  result     String
  requestId  String
  ipAddress  String?
  userAgent  String?
  details    Json

  @@index([createdAt(sort: Desc)])
  @@index([module, action])
}

model CmsRelease {
  id                     String               @id @default(cuid())
  version                Int                  @unique
  publishedAt            DateTime             @default(now())
  actorId                String
  actorEmail             String
  frontendRevalidatedAt  DateTime?
  frontendRevalidateOk   Boolean?
  frontendRevalidateNote String?
  createdAt              DateTime             @default(now())
  siteShell              SiteShellPublished[]
  homepage               HomepagePublished[]
  toolContent            ToolContentPublished[]
  seoConfig              SeoConfigPublished[]
  integrations           IntegrationPublished[]
  adPlacements           AdPlacementPublished[]
  adsTxt                 AdsTxtPublished[]
  legalPages             LegalPagePublished[]
  legalSections          LegalPageSectionPublished[]
  faqEntries             FaqEntryPublished[]
  guides                 GuidePublished[]
}

model SiteShellDraft {
  id        String   @id
  version   Int
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteShellPublished {
  id          String     @id
  version     Int
  data        Json
  publishedAt DateTime
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  releaseId   String
  release     CmsRelease @relation(fields: [releaseId], references: [id], onDelete: Cascade)
}

model HomepageDraft {
  id        String   @id
  version   Int
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HomepagePublished {
  id          String     @id
  version     Int
  data        Json
  publishedAt DateTime
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  releaseId   String
  release     CmsRelease @relation(fields: [releaseId], references: [id], onDelete: Cascade)
}

model ToolContentDraft {
  id        String   @id
  version   Int
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ToolContentPublished {
  id          String     @id
  version     Int
  data        Json
  publishedAt DateTime
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  releaseId   String
  release     CmsRelease @relation(fields: [releaseId], references: [id], onDelete: Cascade)
}

model SeoConfigDraft {
  id        String   @id
  version   Int
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SeoConfigPublished {
  id          String     @id
  version     Int
  data        Json
  publishedAt DateTime
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  releaseId   String
  release     CmsRelease @relation(fields: [releaseId], references: [id], onDelete: Cascade)
}

model IntegrationDraft {
  id              String   @id
  kind            String
  enabled         Boolean
  scope           String
  environment     String
  notes           String
  lastPublishedAt DateTime?
  config          Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([kind])
}

model IntegrationPublished {
  id              String     @id
  kind            String
  enabled         Boolean
  scope           String
  environment     String
  notes           String
  lastPublishedAt DateTime?
  config          Json
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  publishedAt     DateTime
  releaseId       String
  release         CmsRelease @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@index([kind])
}

model AdPlacementDraft {
  id              String   @id
  name            String
  provider        String
  enabled         Boolean
  slotId          String
  scopes          String[]
  categories      String[]
  environment     String
  notes           String
  lastPublishedAt DateTime?
  config          Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([slotId])
}

model AdPlacementPublished {
  id              String     @id
  name            String
  provider        String
  enabled         Boolean
  slotId          String
  scopes          String[]
  categories      String[]
  environment     String
  notes           String
  lastPublishedAt DateTime?
  config          Json
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  publishedAt     DateTime
  releaseId       String
  release         CmsRelease @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@index([slotId])
}

model AdsTxtDraft {
  id        String   @id
  version   Int
  lines     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdsTxtPublished {
  id          String     @id
  version     Int
  lines       Json
  publishedAt DateTime
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  releaseId   String
  release     CmsRelease @relation(fields: [releaseId], references: [id], onDelete: Cascade)
}

model LegalPageDraft {
  id             String                  @id
  slug           String                  @unique
  eyebrow        String?
  title          String
  description    String
  ctaTitle       String?
  ctaDescription String?
  ctaLabel       String?
  ctaHref        String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  sections       LegalPageSectionDraft[]
}

model LegalPageSectionDraft {
  id        String         @id @default(cuid())
  pageId    String
  heading   String
  body      String
  order     Int
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  page      LegalPageDraft @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, order])
}

model LegalPagePublished {
  id             String                      @id
  slug           String                      @unique
  eyebrow        String?
  title          String
  description    String
  ctaTitle       String?
  ctaDescription String?
  ctaLabel       String?
  ctaHref        String?
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt
  publishedAt    DateTime
  releaseId      String
  release        CmsRelease                  @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  sections       LegalPageSectionPublished[]
}

model LegalPageSectionPublished {
  id          String             @id @default(cuid())
  pageId       String
  heading      String
  body         String
  order        Int
  publishedAt  DateTime
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  releaseId    String
  release      CmsRelease        @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  page         LegalPagePublished @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, order])
}

model FaqEntryDraft {
  id        String   @id
  question  String
  answer    String
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
}

model FaqEntryPublished {
  id          String     @id
  question    String
  answer      String
  order       Int
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  publishedAt DateTime
  releaseId   String
  release     CmsRelease @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@index([order])
}

model GuideDraft {
  id          String   @id
  slug        String   @unique
  title       String
  excerpt     String
  category    String
  body        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
}

model GuidePublished {
  id          String     @id
  slug        String     @unique
  title       String
  excerpt     String
  category    String
  body        String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  publishedAt DateTime
  releaseId   String
  release     CmsRelease @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@index([category])
}

model VisitorEvent {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  path       String
  referrer   String?
  timezone   String?
  deviceType String
  browser    String
  os         String
  country    String?
  city       String?
  ipHash     String?
  userAgent  String?

  @@index([createdAt(sort: Desc)])
  @@index([path])
}
