# Copy to `.env` and replace every placeholder before real deployment.
# true  -> use DEV_* values
# false -> use PROD_* values
APP_DEV=true
NEXT_PUBLIC_APP_DEV=true

# Compose image tags
BACKEND_IMAGE=replace-backend-image-tag
FRONTEND_IMAGE=replace-frontend-image-tag
CMS_BACKEND_IMAGE=replace-cms-backend-image-tag
CMS_FRONTEND_IMAGE=replace-cms-frontend-image-tag

# Public frontend
NEXT_PUBLIC_DEV_SITE_ORIGIN=http://localhost:3000
NEXT_PUBLIC_PROD_SITE_ORIGIN=https://pdf.example.invalid
DEV_PUBLIC_SITE_ORIGIN=http://localhost:3000
PROD_PUBLIC_SITE_ORIGIN=https://pdf.example.invalid
PROD_PUBLIC_HOSTNAME=pdf.example.invalid

# Private PDF backend
DEV_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
PROD_ALLOWED_ORIGINS=https://pdf.example.invalid
DEV_ALLOWED_HOSTS=localhost,127.0.0.1,pdf-toolkit-backend
PROD_ALLOWED_HOSTS=pdf.example.invalid,localhost,127.0.0.1,pdf-toolkit-backend
DEV_TRUST_PROXY=false
PROD_TRUST_PROXY=true
DEV_RATE_LIMIT_MAX_REQUESTS=60
PROD_RATE_LIMIT_MAX_REQUESTS=60
DEV_RATE_LIMIT_WINDOW_SECONDS=60
PROD_RATE_LIMIT_WINDOW_SECONDS=60
DEV_CONTACT_RATE_LIMIT_MAX_REQUESTS=5
PROD_CONTACT_RATE_LIMIT_MAX_REQUESTS=5
DEV_CONTACT_RATE_LIMIT_WINDOW_SECONDS=600
PROD_CONTACT_RATE_LIMIT_WINDOW_SECONDS=600
DEV_CONTACT_RATE_LIMIT_IP_MAX_REQUESTS=3
PROD_CONTACT_RATE_LIMIT_IP_MAX_REQUESTS=3
DEV_CONTACT_RATE_LIMIT_IP_WINDOW_SECONDS=3600
PROD_CONTACT_RATE_LIMIT_IP_WINDOW_SECONDS=3600
DEV_CONTACT_RATE_LIMIT_EMAIL_MAX_REQUESTS=2
PROD_CONTACT_RATE_LIMIT_EMAIL_MAX_REQUESTS=2
DEV_CONTACT_RATE_LIMIT_EMAIL_WINDOW_SECONDS=86400
PROD_CONTACT_RATE_LIMIT_EMAIL_WINDOW_SECONDS=86400
DEV_CONTACT_RATE_LIMIT_PAYLOAD_MAX_REQUESTS=1
PROD_CONTACT_RATE_LIMIT_PAYLOAD_MAX_REQUESTS=1
DEV_CONTACT_RATE_LIMIT_PAYLOAD_WINDOW_SECONDS=600
PROD_CONTACT_RATE_LIMIT_PAYLOAD_WINDOW_SECONDS=600
DEV_CONTACT_MAX_LINKS=2
PROD_CONTACT_MAX_LINKS=2
DEV_MAX_UPLOAD_MB=25
PROD_MAX_UPLOAD_MB=25
DEV_INTERNAL_API_ORIGIN=http://localhost:8000
PROD_INTERNAL_API_ORIGIN=http://pdf-toolkit-backend:8000
DEV_DOCKER_INTERNAL_API_ORIGIN=http://pdf-toolkit-backend:8000
PROD_DOCKER_INTERNAL_API_ORIGIN=http://pdf-toolkit-backend:8000
DEV_INTERNAL_API_TOKEN=replace-with-dev-internal-token
PROD_INTERNAL_API_TOKEN=replace-with-prod-internal-token
DEV_REDIS_PDF_PREFIX=pdf-dev
PROD_REDIS_PDF_PREFIX=pdf-prod

# CMS public origins
DEV_CMS_WEB_ORIGIN=http://localhost:3100
PROD_CMS_WEB_ORIGIN=https://cms.example.invalid
DEV_CMS_API_ORIGIN=http://localhost:4100
PROD_CMS_API_ORIGIN=https://cms-api.example.invalid
DEV_CMS_API_INTERNAL_ORIGIN=http://localhost:4100
PROD_CMS_API_INTERNAL_ORIGIN=http://cms-backend-api:4100
DEV_DOCKER_CMS_API_INTERNAL_ORIGIN=http://cms-backend-api:4100
PROD_DOCKER_CMS_API_INTERNAL_ORIGIN=http://cms-backend-api:4100
PROD_CMS_WEB_HOSTNAME=cms.example.invalid
PROD_CMS_API_HOSTNAME=cms-api.example.invalid

# CMS runtime and auth
DEV_CMS_API_PORT=4100
PROD_CMS_API_PORT=4100
DEV_CMS_SESSION_SECRET=replace-with-dev-cms-session-secret
PROD_CMS_SESSION_SECRET=replace-with-prod-cms-session-secret
DEV_CMS_COOKIE_SECURE=false
PROD_CMS_COOKIE_SECURE=true
DEV_CMS_COOKIE_DOMAIN=
PROD_CMS_COOKIE_DOMAIN=.example.invalid
DEV_CMS_SESSION_TTL_SECONDS=43200
PROD_CMS_SESSION_TTL_SECONDS=43200
DEV_CMS_REVALIDATE_SECRET=replace-with-dev-cms-revalidate-secret
PROD_CMS_REVALIDATE_SECRET=replace-with-prod-cms-revalidate-secret
DEV_CMS_INGEST_SECRET=replace-with-dev-cms-ingest-secret
PROD_CMS_INGEST_SECRET=replace-with-prod-cms-ingest-secret
DEV_CMS_TOTP_ISSUER=PDF Toolkit CMS Dev
PROD_CMS_TOTP_ISSUER=PDF Toolkit CMS
DEV_PUBLIC_SITE_REVALIDATE_URL=http://localhost:3000/api/revalidate/cms
PROD_PUBLIC_SITE_REVALIDATE_URL=http://pdf-toolkit-frontend:3000/api/revalidate/cms
DEV_DOCKER_PUBLIC_SITE_REVALIDATE_URL=http://pdf-toolkit-frontend:3000/api/revalidate/cms
PROD_DOCKER_PUBLIC_SITE_REVALIDATE_URL=http://pdf-toolkit-frontend:3000/api/revalidate/cms
DEV_CMS_SUPERADMIN_EMAIL=replace-with-dev-admin@example.invalid
PROD_CMS_SUPERADMIN_EMAIL=replace-with-prod-admin@example.invalid
DEV_CMS_SUPERADMIN_PASSWORD=replace-with-dev-superadmin-password
PROD_CMS_SUPERADMIN_PASSWORD=replace-with-prod-superadmin-password
DEV_CMS_SUPERADMIN_NAME=Replace Dev Super Admin
PROD_CMS_SUPERADMIN_NAME=Replace Prod Super Admin
DEV_CMS_ADMIN_EMAIL=replace-with-dev-admin.invalid
PROD_CMS_ADMIN_EMAIL=replace-with-prod-admin.invalid
DEV_CMS_ADMIN_PASSWORD=replace-with-dev-admin-password
PROD_CMS_ADMIN_PASSWORD=replace-with-prod-admin-password
DEV_CMS_ADMIN_NAME=Replace Dev Admin
PROD_CMS_ADMIN_NAME=Replace Prod Admin

# CMS persistence and shared cache
DEV_DOCKER_POSTGRES_URL=postgresql://replace-dev-user:replace-dev-password@host.docker.internal:5432/replace_dev_db?schema=public
PROD_DOCKER_POSTGRES_URL=postgresql://replace-prod-user:replace-prod-password@replace-prod-db-host:5432/replace_prod_db?schema=public
DEV_DOCKER_REDIS_URL=redis://:replace-dev-redis-password@host.docker.internal:6379/0
PROD_DOCKER_REDIS_URL=redis://:replace-prod-redis-password@replace-prod-redis-host:6379/0
DEV_REDIS_CMS_PREFIX=cms-dev
PROD_REDIS_CMS_PREFIX=cms-prod
DEV_ANALYTICS_ENABLED=true
PROD_ANALYTICS_ENABLED=true
DEV_LOG_LEVEL=info
PROD_LOG_LEVEL=info

# SMTP
DEV_SMTP_HOST=replace-dev-smtp-host
PROD_SMTP_HOST=replace-prod-smtp-host
DEV_SMTP_PORT=1025
PROD_SMTP_PORT=587
DEV_SMTP_SECURE=false
PROD_SMTP_SECURE=true
DEV_SMTP_USER=replace-dev-smtp-user
PROD_SMTP_USER=replace-prod-smtp-user
DEV_SMTP_PASSWORD=replace-dev-gmail-app-password
PROD_SMTP_PASSWORD=replace-prod-gmail-app-password
DEV_SMTP_FROM_ADDRESS=replace-dev-from@example.invalid
PROD_SMTP_FROM_ADDRESS=replace-prod-from@example.invalid
