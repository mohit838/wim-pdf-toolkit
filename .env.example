# Toggle both flags together.
# true  -> use DEV_* and NEXT_PUBLIC_DEV_* values
# false -> use PROD_* and NEXT_PUBLIC_PROD_* values
APP_DEV=<true_or_false>
NEXT_PUBLIC_APP_DEV=<true_or_false>

# Compose image tags
BACKEND_IMAGE=replace-backend_image
FRONTEND_IMAGE=replace-frontend_image
CMS_BACKEND_IMAGE=replace-cms_backend_image
CMS_FRONTEND_IMAGE=replace-cms_frontend_image

# ----------------------------
# DEV (host machine)
# ----------------------------

# Public frontend
NEXT_PUBLIC_DEV_SITE_ORIGIN=https://example.invalid
DEV_PUBLIC_SITE_ORIGIN=https://example.invalid

# Private PDF backend
DEV_ALLOWED_ORIGINS=replace-dev_allowed_origins
DEV_ALLOWED_HOSTS=replace-dev_allowed_hosts
DEV_TRUST_PROXY=<true_or_false>
DEV_RATE_LIMIT_MAX_REQUESTS=<number>
DEV_RATE_LIMIT_WINDOW_SECONDS=<number>
DEV_CONTACT_RATE_LIMIT_MAX_REQUESTS=<number>
DEV_CONTACT_RATE_LIMIT_WINDOW_SECONDS=<number>
DEV_CONTACT_RATE_LIMIT_IP_MAX_REQUESTS=<number>
DEV_CONTACT_RATE_LIMIT_IP_WINDOW_SECONDS=<number>
DEV_CONTACT_RATE_LIMIT_EMAIL_MAX_REQUESTS=<number>
DEV_CONTACT_RATE_LIMIT_EMAIL_WINDOW_SECONDS=<number>
DEV_CONTACT_RATE_LIMIT_PAYLOAD_MAX_REQUESTS=<number>
DEV_CONTACT_RATE_LIMIT_PAYLOAD_WINDOW_SECONDS=<number>
DEV_CONTACT_MAX_LINKS=<number>
DEV_MAX_UPLOAD_MB=<number>
DEV_INTERNAL_API_ORIGIN=http://service.example.invalid
DEV_INTERNAL_API_TOKEN=replace-with-dev_internal_api_token
DEV_REDIS_PDF_PREFIX=replace-dev_redis_pdf_prefix

# CMS public origins
DEV_CMS_WEB_ORIGIN=https://example.invalid
DEV_CMS_API_ORIGIN=https://example.invalid
DEV_CMS_API_INTERNAL_ORIGIN=http://service.example.invalid

# CMS runtime and auth
DEV_CMS_API_PORT=<port>
DEV_CMS_SESSION_SECRET=replace-with-dev_cms_session_secret
DEV_CMS_COOKIE_SECURE=<true_or_false>
DEV_CMS_COOKIE_DOMAIN=replace-dev_cms_cookie_domain
DEV_CMS_SESSION_TTL_SECONDS=<number>
DEV_CMS_REVALIDATE_SECRET=replace-with-dev_cms_revalidate_secret
DEV_CMS_INGEST_SECRET=replace-with-dev_cms_ingest_secret
DEV_CMS_TOTP_ISSUER=replace-dev_cms_totp_issuer
DEV_PUBLIC_SITE_REVALIDATE_URL=http://service.example.invalid
DEV_CMS_SUPERADMIN_EMAIL=user@example.invalid
DEV_CMS_SUPERADMIN_PASSWORD=replace-with-dev_cms_superadmin_password
DEV_CMS_SUPERADMIN_NAME=replace-dev_cms_superadmin_name
DEV_CMS_ADMIN_EMAIL=user@example.invalid
DEV_CMS_ADMIN_PASSWORD=replace-with-dev_cms_admin_password
DEV_CMS_ADMIN_NAME=replace-dev_cms_admin_name

# CMS persistence and cache
DEV_REDIS_CMS_PREFIX=replace-dev_redis_cms_prefix

# Flags and SMTP
DEV_ANALYTICS_ENABLED=<true_or_false>
DEV_LOG_LEVEL=replace-dev_log_level
DEV_SMTP_HOST=replace-dev_smtp_host
DEV_SMTP_PORT=<port>
DEV_SMTP_SECURE=<true_or_false>
DEV_SMTP_USER=replace-dev_smtp_user
DEV_SMTP_PASSWORD=replace-with-dev_smtp_password
DEV_SMTP_FROM_ADDRESS=user@example.invalid

# ----------------------------
# PROD (host machine)
# ----------------------------

# Public frontend
NEXT_PUBLIC_PROD_SITE_ORIGIN=https://example.invalid
PROD_PUBLIC_SITE_ORIGIN=https://example.invalid
PROD_PUBLIC_HOSTNAME=example.invalid

# Private PDF backend
PROD_ALLOWED_ORIGINS=replace-prod_allowed_origins
PROD_ALLOWED_HOSTS=replace-prod_allowed_hosts
PROD_TRUST_PROXY=<true_or_false>
PROD_RATE_LIMIT_MAX_REQUESTS=<number>
PROD_RATE_LIMIT_WINDOW_SECONDS=<number>
PROD_CONTACT_RATE_LIMIT_MAX_REQUESTS=<number>
PROD_CONTACT_RATE_LIMIT_WINDOW_SECONDS=<number>
PROD_CONTACT_RATE_LIMIT_IP_MAX_REQUESTS=<number>
PROD_CONTACT_RATE_LIMIT_IP_WINDOW_SECONDS=<number>
PROD_CONTACT_RATE_LIMIT_EMAIL_MAX_REQUESTS=<number>
PROD_CONTACT_RATE_LIMIT_EMAIL_WINDOW_SECONDS=<number>
PROD_CONTACT_RATE_LIMIT_PAYLOAD_MAX_REQUESTS=<number>
PROD_CONTACT_RATE_LIMIT_PAYLOAD_WINDOW_SECONDS=<number>
PROD_CONTACT_MAX_LINKS=<number>
PROD_MAX_UPLOAD_MB=<number>
PROD_INTERNAL_API_ORIGIN=http://service.example.invalid
PROD_INTERNAL_API_TOKEN=replace-with-prod_internal_api_token
PROD_REDIS_PDF_PREFIX=replace-prod_redis_pdf_prefix

# CMS public origins
PROD_CMS_WEB_ORIGIN=https://example.invalid
PROD_CMS_API_ORIGIN=https://example.invalid
PROD_CMS_API_INTERNAL_ORIGIN=http://service.example.invalid
PROD_CMS_WEB_HOSTNAME=example.invalid
PROD_CMS_API_HOSTNAME=example.invalid

# CMS runtime and auth
PROD_CMS_API_PORT=<port>
PROD_CMS_SESSION_SECRET=replace-with-prod_cms_session_secret
PROD_CMS_COOKIE_SECURE=<true_or_false>
PROD_CMS_COOKIE_DOMAIN=replace-prod_cms_cookie_domain
PROD_CMS_SESSION_TTL_SECONDS=<number>
PROD_CMS_REVALIDATE_SECRET=replace-with-prod_cms_revalidate_secret
PROD_CMS_INGEST_SECRET=replace-with-prod_cms_ingest_secret
PROD_CMS_TOTP_ISSUER=replace-prod_cms_totp_issuer
PROD_PUBLIC_SITE_REVALIDATE_URL=http://service.example.invalid
PROD_CMS_SUPERADMIN_EMAIL=user@example.invalid
PROD_CMS_SUPERADMIN_PASSWORD=replace-with-prod_cms_superadmin_password
PROD_CMS_SUPERADMIN_NAME=replace-prod_cms_superadmin_name
PROD_CMS_ADMIN_EMAIL=user@example.invalid
PROD_CMS_ADMIN_PASSWORD=replace-with-prod_cms_admin_password
PROD_CMS_ADMIN_NAME=replace-prod_cms_admin_name

# CMS persistence and cache
PROD_REDIS_CMS_PREFIX=replace-prod_redis_cms_prefix

# Flags and SMTP
PROD_ANALYTICS_ENABLED=<true_or_false>
PROD_LOG_LEVEL=replace-prod_log_level
PROD_SMTP_HOST=replace-prod_smtp_host
PROD_SMTP_PORT=<port>
PROD_SMTP_SECURE=<true_or_false>
PROD_SMTP_USER=replace-prod_smtp_user
PROD_SMTP_PASSWORD=replace-with-prod_smtp_password
PROD_SMTP_FROM_ADDRESS=user@example.invalid

# ----------------------------
# DOCKER DEV
# ----------------------------
DEV_DOCKER_INTERNAL_API_ORIGIN=http://service.example.invalid
DEV_DOCKER_CMS_API_INTERNAL_ORIGIN=http://service.example.invalid
DEV_DOCKER_PUBLIC_SITE_REVALIDATE_URL=http://service.example.invalid
DEV_DOCKER_POSTGRES_URL=https://example.invalid
DEV_DOCKER_REDIS_URL=https://example.invalid

# ----------------------------
# DOCKER PROD
# ----------------------------
PROD_DOCKER_INTERNAL_API_ORIGIN=http://service.example.invalid
PROD_DOCKER_CMS_API_INTERNAL_ORIGIN=http://service.example.invalid
PROD_DOCKER_PUBLIC_SITE_REVALIDATE_URL=http://service.example.invalid
PROD_DOCKER_POSTGRES_URL=https://example.invalid
PROD_DOCKER_REDIS_URL=https://example.invalid
